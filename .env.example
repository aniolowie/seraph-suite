# ============================================================
# Seraph Suite — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- LLM APIs ---
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...           # Fallback LLM provider

# --- Local model (Ollama) ---
# Set LOCAL_MODEL_ENABLED=true to use a local model instead of Anthropic.
# Run `ollama pull qwen2.5-coder:8b` first, then start Ollama.
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=qwen2.5-coder:8b

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # Leave empty for local (no auth)
QDRANT_COLLECTION_NAME=seraph_kb

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=seraph_secret

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Embedding Models (local paths or HF hub IDs) ---
DENSE_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Models cache dir ---
MODELS_DIR=./data/models

# --- Seraph Config ---
LOG_LEVEL=INFO
ENV=development                        # development | production
MAX_RETRIEVAL_DOCS=20
RERANK_TOP_K=5

# --- HTB Benchmarking ---
HTB_VPN_INTERFACE=tun0                 # Network interface for HTB VPN
HTB_API_TOKEN=                         # Optional: HTB API for machine info

# --- Optional: NVD API (higher rate limits) ---
NVD_API_KEY=
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# --- Ingestion ---
SQLITE_DB_PATH=./data/seraph_state.db
INGESTION_BATCH_SIZE=100
EXPLOITDB_MIRROR_PATH=./data/exploitdb
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# --- API / Dashboard (Phase 7) ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # Comma-separated allowed origins
API_RATE_LIMIT_PER_MINUTE=60                             # Requests per IP per minute
REPORTS_DIR=./data/reports                               # Directory for benchmark JSON reports

# --- Sandbox / Docker Isolation (Phase 5) ---
SANDBOX_ENABLED=false                  # Set true to route tools through Docker sandbox
SANDBOX_IMAGE=seraph-agent:latest      # Docker image built by `make sandbox-build`
SANDBOX_CPU_LIMIT=1.0                  # CPU cores per container
SANDBOX_MEMORY_LIMIT_MB=512            # MiB RAM per container
SANDBOX_POOL_SIZE=3                    # Warm containers to maintain
SANDBOX_POOL_TIMEOUT_SECONDS=30        # Wait limit before ContainerPoolExhaustedError
SANDBOX_CONTAINER_TIMEOUT=3600         # Max container lifetime in seconds
SANDBOX_DATA_VOLUME=./data             # Host path mounted into containers
SANDBOX_NETWORK_NAME=seraph-agent-net  # Docker bridge network for agents
